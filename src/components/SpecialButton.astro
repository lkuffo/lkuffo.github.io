    'blog': '/posts',
    'webscraping': ''
};


const { text, color, icon="", href = "" } = Astro.props;

let className = `min-w-48 font-mono w-fit h-16 p-2 text-black font-thin ${colorVariants[color]} duration-150 hover:!border-b-2 text-black rounded-xl drop-shadow-sm group flex flex-col items-center align-center justify-center border-2 border-b-4 border-blue-950 cursor-pointer active:${colorVariants[color]} overflow-hidden`;

let hrefSolving = hrefMapping[icon];
if (href.length > 0){
    hrefSolving = href
}
